---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { BUILD_STATUS_LABELS } from '../content.config.ts';

const builds = (await getCollection('builds')).sort(
  (a, b) => a.data.order - b.data.order,
);

const statusClass: Record<keyof typeof BUILD_STATUS_LABELS, string> = {
  live: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
  'open-source': 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/40 dark:text-indigo-300',
  sold: 'bg-gray-200 text-gray-700 dark:bg-gray-700 dark:text-gray-300',
};
---

<BaseLayout
  title="Builds"
  description="Products and projects Carlos Vilhena has built — software, tools, and side quests."
>
  <div class="max-w-4xl mx-auto">
    <header class="mb-10">
      <h1 class="text-4xl md:text-5xl font-semibold mb-4">Builds</h1>
      <p class="text-xl text-gray-500 dark:text-gray-400">
        Products and projects I've made over the years. Some are live, some are
        sold — all of them taught me something.
      </p>
    </header>

    <ul class="grid grid-cols-1 md:grid-cols-2 gap-5 list-none p-0 m-0">
      {builds.map((build) => {
        const Tag = build.data.url ? 'a' : 'div';
        const linkProps = build.data.url
          ? { href: build.data.url, target: '_blank', rel: 'noopener' }
          : {};
        return (
          <li class="m-0">
            <Tag
              {...linkProps}
              class="group block h-full p-6 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-gray-400 dark:hover:border-gray-600 hover:shadow-sm transition-colors no-underline"
            >
              <div class="flex items-start gap-4 mb-3">
                {build.data.logo ? (
                  <Image
                    src={build.data.logo}
                    alt={`${build.data.title} logo`}
                    width={64}
                    height={64}
                    class="w-16 h-16 rounded-lg object-contain flex-shrink-0 m-0"
                  />
                ) : (
                  <div class="w-16 h-16 rounded-lg bg-gray-100 dark:bg-gray-800 flex-shrink-0" aria-hidden="true" />
                )}
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between gap-2 mb-1">
                    <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 m-0 truncate">
                      {build.data.title}
                    </h2>
                    <span class={`text-xs font-medium px-2 py-0.5 rounded-full whitespace-nowrap ${statusClass[build.data.status]}`}>
                      {BUILD_STATUS_LABELS[build.data.status]}
                    </span>
                  </div>
                </div>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400 m-0 mb-4 leading-relaxed">
                {build.data.description}
              </p>
              {build.data.url && (
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:underline">
                  Visit <span aria-hidden="true">→</span>
                </span>
              )}
            </Tag>
          </li>
        );
      })}
    </ul>
  </div>
</BaseLayout>
