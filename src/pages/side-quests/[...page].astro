---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import CategoryPage from '../../components/CategoryPage.astro';

const CATEGORY = 'side-quests';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const all = await getCollection('posts', ({ data }) => !data.draft && data.category === 'side-quests');
  const sorted = all.sort(
    (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
  );
  return paginate(sorted, { pageSize: 10 });
};

const { page } = Astro.props;
const slugOf = (id: string) => id.replace(/\/index$/, '').split('/').pop()!;

const posts = page.data.map((post) => ({
  id: post.id,
  url: `/${slugOf(post.id)}/`,
  frontmatter: post.data,
}));

const pagination = {
  currentPage: page.currentPage,
  lastPage: page.lastPage,
  size: page.size,
  total: page.total,
  prevUrl: page.url.prev,
  nextUrl: page.url.next,
};
---

<CategoryPage category={CATEGORY} posts={posts} pagination={pagination} />
