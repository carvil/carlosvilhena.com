---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../content.config.ts';

const all = await getCollection('posts', ({ data }) => !data.draft);
const sorted = all.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const slugOf = (id: string) => id.replace(/\/index$/, '').split('/').pop()!;

const byCategory = (Object.keys(CATEGORIES) as (keyof typeof CATEGORIES)[]).map(
  (cat) => ({
    slug: cat,
    label: CATEGORIES[cat].label,
    intro: CATEGORIES[cat].intro,
    posts: sorted
      .filter((p) => p.data.category === cat)
      .map((p) => ({
        id: p.id,
        url: `/${slugOf(p.id)}/`,
        frontmatter: p.data,
      })),
  }),
);
---

<BaseLayout title="Tiny Delights">
  <div class="max-w-3xl mx-auto">
    <section class="text-center py-[8vh]" transition:animate="fade">
      <h1 class="text-6xl md:text-7xl mb-6 font-bold">Tiny Delights</h1>
      <p class="text-xl md:text-2xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
        Welcome to my blog! My name is Carlos, and I am a builder.
      </p>
    </section>

    {byCategory.map((cat) => (
      <section class="mt-12" transition:animate="fade">
        <header class="mb-2">
          <h2 class="text-2xl font-semibold">
            <a href={`/${cat.slug}/`} class="hover:underline">{cat.label}</a>
          </h2>
          <p class="text-gray-500 dark:text-gray-400 mt-1">{cat.intro}</p>
        </header>
        <PostList posts={cat.posts} showDescription={false} />
      </section>
    ))}
  </div>
</BaseLayout>
