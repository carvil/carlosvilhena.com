---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const entry = await getEntry('pages', slug);
if (!entry) {
  throw new Error(`[carlosvilhena.com] page content not found for slug "${slug}"`);
}
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-3xl mx-auto">
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl mb-4 font-semibold">{entry.data.title}</h1>
      {entry.data.description && (
        <p class="text-xl text-gray-500 dark:text-gray-400">{entry.data.description}</p>
      )}
    </header>
    <div class="prose prose-xl dark:prose-invert">
      <Content />
    </div>
  </article>
</BaseLayout>
