---
import { CATEGORIES } from '../content.config.ts';

type CategorySlug = keyof typeof CATEGORIES;

interface Props {
  post: {
    id: string;
    url: string;
    frontmatter: {
      title: string;
      description: string;
      category?: CategorySlug;
      tags?: string[];
    };
  };
  showDescription?: boolean;
  showTags?: boolean;
  /** Show the category label on the right (brook-2-style row). */
  showCategory?: boolean;
}

const { post, showDescription = true, showTags = false, showCategory = false } = Astro.props;
const { title, description, category, tags } = post.frontmatter;
const categoryMeta = category ? CATEGORIES[category] : null;
---

<article class="border-t border-gray-200 dark:border-gray-800 py-6" transition:name={`post-${post.id}`}>
  <div class:list={[
    'gap-4',
    showCategory ? 'flex flex-col sm:flex-row sm:justify-between sm:items-baseline' : '',
  ]}>
    <h2 class:list={[
      showCategory ? 'text-xl md:text-2xl' : 'text-xl md:text-2xl mb-2',
    ]}>
      <a
        href={post.url}
        class="hover:underline focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 rounded"
      >
        {title}
      </a>
    </h2>

    {showCategory && categoryMeta && (
      <a
        href={`/${category}/`}
        class="text-sm text-gray-500 dark:text-gray-400 shrink-0 sm:text-right hover:underline whitespace-nowrap"
        aria-label={`More posts in ${categoryMeta.label}`}
      >
        {categoryMeta.label}
      </a>
    )}
  </div>

  {showTags && tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-3" aria-label="Tags">
      {tags.map((tag) => (
        <a
          href={`/tags/${tag}/`}
          class="inline-flex items-center rounded-md bg-gray-100 dark:bg-gray-800 px-2.5 py-0.5 text-xs font-medium text-gray-800 dark:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-700"
          aria-label={`View all posts tagged ${tag}`}
        >
          {tag}
        </a>
      ))}
    </div>
  )}

  {showDescription && description && (
    <p class="text-gray-500 dark:text-gray-400 mt-2">{description}</p>
  )}
</article>
