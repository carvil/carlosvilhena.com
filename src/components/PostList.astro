---
import PostCard from './PostCard.astro';

interface PostItem {
  id: string;
  url: string;
  frontmatter: {
    title: string;
    description: string;
    tags?: string[];
  };
}

interface Props {
  posts: PostItem[];
  showDescription?: boolean;
  showTags?: boolean;
  title?: string;
}

const { posts, showDescription = true, showTags = false, title } = Astro.props;
---

<section aria-labelledby={title ? 'post-list-title' : undefined}>
  {title && <h2 id="post-list-title" class="text-2xl font-semibold mb-4">{title}</h2>}

  <div class="border-b border-gray-200 dark:border-gray-800" role="feed" aria-busy="false">
    {posts.length === 0 ? (
      <p class="py-8 text-gray-500 text-center">No posts yet.</p>
    ) : (
      posts.map((post) => (
        <PostCard post={post} showDescription={showDescription} showTags={showTags} />
      ))
    )}
  </div>
</section>
