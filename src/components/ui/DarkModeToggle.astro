---
// Three-state theme toggle. Visible icon reflects the current mode:
// sun = Light, moon = Dark, monitor = System. Click cycles forward.
// Mode is read from the [data-theme-mode] attribute set on <html> by
// the inline theme script in BaseLayout.astro.
---

<button
  class="theme-toggle flex items-center justify-center w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 dark:bg-gray-900 dark:hover:bg-gray-800 transition-colors duration-200 p-2"
  aria-label="Toggle theme"
  title="Toggle theme"
>
  <!-- Sun (Light mode) -->
  <svg
    class="icon-light w-4 h-4 text-gray-700 dark:text-gray-200"
    fill="currentColor"
    viewBox="0 0 20 20"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      fill-rule="evenodd"
      d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
      clip-rule="evenodd"
    ></path>
  </svg>

  <!-- Moon (Dark mode) -->
  <svg
    class="icon-dark w-4 h-4 text-gray-700 dark:text-gray-200"
    fill="currentColor"
    viewBox="0 0 20 20"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
  </svg>

  <!-- Monitor (System mode — follows OS pref) -->
  <svg
    class="icon-system w-4 h-4 text-gray-700 dark:text-gray-200"
    fill="currentColor"
    viewBox="0 0 20 20"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      fill-rule="evenodd"
      d="M2 5a2 2 0 012-2h12a2 2 0 012 2v8a2 2 0 01-2 2h-3l1 2h1a1 1 0 110 2H7a1 1 0 110-2h1l1-2H4a2 2 0 01-2-2V5zm14 0H4v8h12V5z"
      clip-rule="evenodd"
    ></path>
  </svg>
</button>

<style>
  .icon-light,
  .icon-dark,
  .icon-system {
    display: none;
  }
  :global([data-theme-mode='light']) .icon-light {
    display: block;
  }
  :global([data-theme-mode='dark']) .icon-dark {
    display: block;
  }
  :global([data-theme-mode='system']) .icon-system {
    display: block;
  }
</style>
