---
import { Icon } from 'astro-icon/components';
import { CATEGORIES } from '../content.config.ts';

type CategorySlug = keyof typeof CATEGORIES;

interface Props {
  category: CategorySlug;
  postCount: number;
}

const { category, postCount } = Astro.props;
const meta = CATEGORIES[category];
const postLabel = postCount === 1 ? 'post' : 'posts';
---

<a
  href={`/${category}/`}
  class="group flex flex-col p-6 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent)] transition-colors duration-200"
  aria-label={`Browse ${meta.label}`}
>
  <Icon
    name={meta.icon}
    class="w-8 h-8 mb-4 accent group-hover:scale-110 transition-transform duration-200"
    aria-hidden="true"
  />
  <h3 class="text-lg font-semibold mb-2 group-hover:underline">{meta.label}</h3>
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 grow">{meta.intro}</p>
  <span class="text-sm accent">
    {postCount} {postLabel} <span aria-hidden="true">→</span>
  </span>
</a>
