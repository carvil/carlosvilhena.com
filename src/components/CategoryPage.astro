---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from './PostList.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../content.config.ts';

interface Props {
  category: keyof typeof CATEGORIES;
}

const { category } = Astro.props;
const meta = CATEGORIES[category];

const all = await getCollection('posts', ({ data }) => !data.draft && data.category === category);
const sorted = all.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const slugOf = (id: string) => id.replace(/\/index$/, '').split('/').pop()!;

const posts = sorted.map((p) => ({
  id: p.id,
  url: `/${slugOf(p.id)}/`,
  frontmatter: p.data,
}));
---

<BaseLayout title={meta.label} description={meta.intro}>
  <div class="max-w-3xl mx-auto">
    <header class="mb-8 flex flex-col items-start gap-4">
      <Icon name={meta.icon} class="w-12 h-12 accent" aria-hidden="true" />
      <h1 class="text-4xl md:text-5xl font-semibold">{meta.label}</h1>
      <p class="text-xl text-gray-500 dark:text-gray-400">{meta.intro}</p>
    </header>

    <PostList posts={posts} showDescription />
  </div>
</BaseLayout>
