---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import PostNavigation from '../components/PostNavigation.astro';
import { CATEGORIES } from '../content.config.ts';

interface Frontmatter {
  title: string;
  description: string;
  category: keyof typeof CATEGORIES;
  publishedAt: Date;
  updatedAt?: Date;
  cover?: ImageMetadata;
  coverAlt?: string;
  tags?: string[];
}

interface NavLink {
  url: string;
  title: string;
}

interface Props {
  frontmatter: Frontmatter;
  prevPost?: NavLink | null;
  nextPost?: NavLink | null;
}

const { frontmatter, prevPost, nextPost } = Astro.props;
const { title, description, category, publishedAt, updatedAt, cover, coverAlt, tags } = frontmatter;
const slug = Astro.url.pathname.split('/').filter(Boolean).pop();
const categoryLabel = CATEGORIES[category]?.label ?? category;

// Reading time — derived from rendered content, NOT shown next to a date.
const WORDS_PER_MINUTE = 225;
const content = await Astro.slots.render('default');
const contentText = content.replace(/<\/?[^>]+(>|$)/g, ' ');
const wordCount = contentText.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / WORDS_PER_MINUTE));
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  publishedDate={publishedAt}
  modifiedDate={updatedAt}
>
  <article id="main-content">
    <header class="max-w-3xl mx-auto mb-10">
      <div class="text-gray-500 text-sm mb-2 flex flex-wrap items-center gap-2">
        <a href={`/${category}/`} class="hover:underline">{categoryLabel}</a>
        <span aria-hidden="true">·</span>
        <span aria-label={`${readingTime} minute read`}>{readingTime} min read</span>
      </div>
      <h1 class="text-5xl mb-6" transition:name={`title-${slug}`}>{title}</h1>
      {description && <p class="text-xl text-gray-500">{description}</p>}

      {tags && tags.length > 0 && (
        <div class="mt-4 mb-4 flex flex-wrap gap-2" aria-label="Tags">
          {tags.map((tag) => (
            <a href={`/tags/${tag}/`} class="tag" aria-label={`View all posts tagged ${tag}`}>
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    {cover && (
      <div class="max-w-4xl mx-auto mt-2 mb-10 feature-image" transition:name={`image-${slug}`}>
        <Image
          src={cover}
          alt={coverAlt ?? `Cover image for ${title}`}
          class="w-full h-auto object-cover"
          loading="eager"
          widths={[640, 960, 1280, 1600]}
          sizes="(max-width: 768px) 100vw, 1024px"
        />
      </div>
    )}

    <div class="max-w-3xl mx-auto prose prose-xl dark:prose-invert">
      <slot />
    </div>

    {(prevPost || nextPost) && (
      <div class="max-w-3xl mx-auto">
        <PostNavigation prevPost={prevPost ?? null} nextPost={nextPost ?? null} />
      </div>
    )}
  </article>
</BaseLayout>
