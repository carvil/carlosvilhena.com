---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import DarkModeToggle from '../components/ui/DarkModeToggle.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
}

// Two-layer naming:
//   PUBLICATION_NAME — the blog's identity (homepage hero, browser tab, RSS, og:site_name).
//   AUTHOR_NAME      — the human (navbar, footer, JSON-LD Person, Article author).
// Don't collapse them — they serve different surfaces.
const PUBLICATION_NAME = 'Tiny Delights';
const AUTHOR_NAME = 'Carlos Vilhena';
const SITE_TAGLINE = 'Welcome to my blog! My name is Carlos, and I am a builder.';
const DEFAULT_DESCRIPTION =
  'Personal essays by Carlos Vilhena on entrepreneurship, leadership, engineering and STEM education.';

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = '/og-default.jpg',
  type = 'website',
  publishedDate,
  modifiedDate,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = image.startsWith('/') ? new URL(image, Astro.site) : image;

const personLD = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: AUTHOR_NAME,
  url: Astro.site?.toString(),
  sameAs: [
    'https://twitter.com/carvil_',
    'https://www.linkedin.com/in/carlosvilhena',
    'https://github.com/carvil',
    'https://gitlab.com/carvil',
    'https://www.instagram.com/carvil/',
  ],
};

const websiteLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: PUBLICATION_NAME,
  url: Astro.site?.toString(),
  description: DEFAULT_DESCRIPTION,
  author: { '@type': 'Person', name: AUTHOR_NAME },
};

const articleLD = publishedDate
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      image: ogImageURL.toString(),
      author: { '@type': 'Person', name: AUTHOR_NAME, url: Astro.site?.toString() },
      publisher: { '@type': 'Organization', name: PUBLICATION_NAME },
      datePublished: publishedDate.toISOString(),
      dateModified: (modifiedDate ?? publishedDate).toISOString(),
      mainEntityOfPage: canonicalURL.toString(),
    }
  : null;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{type === 'website' && Astro.url.pathname === '/' ? `${PUBLICATION_NAME} — ${AUTHOR_NAME}` : `${title} — ${PUBLICATION_NAME}`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title={PUBLICATION_NAME} href="/rss.xml" />

    <ClientRouter />

    <script is:inline>
      // Theme system — three-state: 'light' | 'dark' | 'system'.
      // 'system' (the default for first-time visitors) follows the OS pref
      // and live-updates when the OS pref changes.
      function getThemeMode() {
        const m = localStorage.theme;
        return m === 'light' || m === 'dark' || m === 'system' ? m : 'system';
      }
      function applyTheme() {
        const mode = getThemeMode();
        document.documentElement.dataset.themeMode = mode;
        const isDark =
          mode === 'dark' ||
          (mode === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', isDark);
      }
      applyTheme();
      window
        .matchMedia('(prefers-color-scheme: dark)')
        .addEventListener('change', () => {
          if (getThemeMode() === 'system') applyTheme();
        });
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={PUBLICATION_NAME} />
    {publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate.toISOString()} />}

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL} />

    <script type="application/ld+json" set:html={JSON.stringify(articleLD ?? websiteLD)} />
    <script type="application/ld+json" set:html={JSON.stringify(personLD)} />

    <style is:inline>
      body {
        font-family: 'Geist Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
      }
      code, pre, kbd, samp {
        font-family: 'Geist Mono', ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace;
      }
    </style>
  </head>
  <body class="text-gray-900 bg-white dark:text-gray-300 dark:bg-black transition-colors duration-300">
    <div class="bg-white dark:bg-black transition-colors duration-300">
      <header class="mx-auto max-w-4xl py-8 px-4">
        <div class="flex items-center justify-between">
          <a href="/" class="text-2xl font-semibold inline-flex items-center gap-2.5" transition:animate="fade">
            <span
              class="w-2.5 h-2.5 rounded-full flex-shrink-0"
              style="background-color: var(--color-accent)"
              aria-hidden="true"
            ></span>
            <span>{AUTHOR_NAME}</span>
          </a>

          <!-- Desktop nav -->
          <div class="hidden md:flex items-center gap-5">
            <nav class="flex items-center gap-5">
              <a href="/about-me/" class="nav-link">About</a>
              <a href="/builds/" class="nav-link">Builds</a>
              <a href="/now/" class="nav-link">Now</a>
              <div class="nav-dropdown relative" data-dropdown>
                <button
                  type="button"
                  class="nav-link nav-link-button flex items-center gap-1"
                  aria-haspopup="true"
                  aria-expanded="false"
                  data-dropdown-trigger
                >
                  Posts
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <!-- Outer wrapper carries pt-2 (invisible bridge) so the
                     mouse can traverse from the trigger to the panel
                     without dropping out of hover state. Inner div has the
                     visible styling. -->
                <div
                  class="dropdown-panel hidden absolute right-0 top-full pt-2 z-20"
                  role="menu"
                  data-dropdown-panel
                >
                  <div class="min-w-[14rem] rounded-md border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 shadow-lg py-1">
                    <a href="/leadership-breadcrumbs/" role="menuitem" class="block px-4 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-900">Leadership Breadcrumbs</a>
                    <a href="/stem-education/" role="menuitem" class="block px-4 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-900">STEM Education</a>
                    <a href="/side-quests/" role="menuitem" class="block px-4 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-900">Side Quests</a>
                    <hr class="my-1 border-gray-200 dark:border-gray-800" />
                    <a href="/posts/" role="menuitem" class="block px-4 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-900">All posts</a>
                  </div>
                </div>
              </div>
            </nav>
            <button
              type="button"
              class="search-trigger flex items-center justify-center w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 dark:bg-gray-900 dark:hover:bg-gray-800 transition-colors"
              aria-label="Search (⌘K)"
              title="Search (⌘K)"
              data-search-open
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4 text-gray-700 dark:text-gray-200" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="m21 21l-4.34-4.34"/><circle cx="11" cy="11" r="8"/></svg>
            </button>
            <DarkModeToggle />
          </div>

          <!-- Mobile nav controls -->
          <div class="md:hidden flex items-center gap-2">
            <button
              type="button"
              class="search-trigger flex items-center justify-center w-8 h-8 rounded-lg bg-gray-100 hover:bg-gray-200 dark:bg-gray-900 dark:hover:bg-gray-800 transition-colors"
              aria-label="Search (⌘K)"
              data-search-open
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4 text-gray-700 dark:text-gray-200" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="m21 21l-4.34-4.34"/><circle cx="11" cy="11" r="8"/></svg>
            </button>
            <DarkModeToggle />
            <button
              id="mobile-menu-button"
              type="button"
              class="inline-flex items-center justify-center p-2 bg-white dark:bg-black text-gray-900 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-900 focus:outline-none border-0"
              aria-expanded="false"
              aria-label="Toggle menu"
            >
              <svg id="menu-icon" class="block h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
              </svg>
              <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile menu drawer -->
        <nav id="mobile-menu" class="hidden md:hidden mt-6 pt-4 border-t border-gray-200 dark:border-gray-800 space-y-1">
          <a href="/about-me/" class="block px-3 py-2 text-sm hover:underline">About</a>
          <a href="/builds/" class="block px-3 py-2 text-sm hover:underline">Builds</a>
          <a href="/now/" class="block px-3 py-2 text-sm hover:underline">Now</a>
          <details class="group">
            <summary class="flex items-center justify-between cursor-pointer list-none px-3 py-2 text-sm hover:underline">
              <span>Posts</span>
              <svg class="w-3 h-3 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="pl-3 mt-1 space-y-1">
              <a href="/leadership-breadcrumbs/" class="block px-3 py-2 text-sm hover:underline">Leadership Breadcrumbs</a>
              <a href="/stem-education/" class="block px-3 py-2 text-sm hover:underline">STEM Education</a>
              <a href="/side-quests/" class="block px-3 py-2 text-sm hover:underline">Side Quests</a>
              <a href="/posts/" class="block px-3 py-2 text-sm hover:underline">All posts</a>
            </div>
          </details>
        </nav>
      </header>

      <main class="py-10 px-4" transition:animate="fade">
        <slot />
      </main>

      <footer class="max-w-4xl mx-auto py-8 px-4 border-t border-gray-200 dark:border-gray-800 mt-12">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
          <div class="text-sm text-gray-500 dark:text-gray-500">© {new Date().getFullYear()} {AUTHOR_NAME}</div>
          <nav class="flex items-center gap-4 text-sm">
            <a href="/get-in-touch/" class="nav-link-footer">Get in touch</a>
            <a href="/rss.xml" class="nav-link-footer">RSS</a>
          </nav>
        </div>
      </footer>
    </div>

    <!-- Search modal — Pagefind UI mounts inside on first invocation -->
    <dialog id="search-dialog" class="search-dialog" aria-labelledby="search-heading">
      <div class="p-4">
        <header class="mb-3 flex items-baseline justify-between">
          <h2 id="search-heading" class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400 font-medium">
            Search
          </h2>
          <kbd class="text-xs text-gray-400 dark:text-gray-500 hidden sm:block">esc to close</kbd>
        </header>
        <div id="pagefind-search-target" class="pagefind-search-target"></div>
        <footer class="mt-3 pt-3 border-t border-gray-200 dark:border-gray-800 text-xs text-gray-500 dark:text-gray-400 flex flex-wrap items-center justify-between gap-2">
          <span>
            <kbd>↑</kbd> <kbd>↓</kbd> navigate · <kbd>↵</kbd> open
          </span>
          <span class="hidden sm:inline">
            Tip: <kbd>⌘</kbd>+<kbd>K</kbd> opens search from anywhere.
          </span>
        </footer>
      </div>
    </dialog>

    <script>
      // Mobile menu toggle (hamburger on small screens)
      function initMobileMenu() {
        const menuButton = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');
        if (!menuButton || !mobileMenu || !menuIcon || !closeIcon) return;
        menuButton.addEventListener('click', () => {
          const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
          mobileMenu.classList.toggle('hidden');
          menuIcon.classList.toggle('hidden');
          closeIcon.classList.toggle('hidden');
          menuButton.setAttribute('aria-expanded', String(!isExpanded));
        });
        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach((link) => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
            menuIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
            menuButton.setAttribute('aria-expanded', 'false');
          });
        });
      }

      // Posts dropdown — hover-open on devices with hover, click-toggle elsewhere.
      // Closes on outside click / Escape / route change.
      function initDropdown() {
        document.querySelectorAll('[data-dropdown]').forEach((dd) => {
          const trigger = dd.querySelector('[data-dropdown-trigger]');
          const panel = dd.querySelector('[data-dropdown-panel]');
          if (!trigger || !panel) return;

          const open = () => {
            panel.classList.remove('hidden');
            trigger.setAttribute('aria-expanded', 'true');
          };
          const close = () => {
            panel.classList.add('hidden');
            trigger.setAttribute('aria-expanded', 'false');
          };

          trigger.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = trigger.getAttribute('aria-expanded') === 'true';
            isOpen ? close() : open();
          });

          // Hover open on devices that support it (desktop)
          if (window.matchMedia('(hover: hover)').matches) {
            dd.addEventListener('mouseenter', open);
            dd.addEventListener('mouseleave', close);
          }

          // Outside click / Escape
          document.addEventListener('click', (e) => {
            if (!dd.contains(e.target)) close();
          });
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') close();
          });
        });
      }

      // Theme toggle — cycles light → dark → system → light.
      // 'system' is stored as no localStorage entry so it auto-tracks
      // future OS pref changes.
      function initThemeToggle() {
        const NEXT = { light: 'dark', dark: 'system', system: 'light' };
        const LABEL = { light: 'Light', dark: 'Dark', system: 'System' };
        const buttons = document.querySelectorAll('.theme-toggle');
        const updateLabels = () => {
          const mode = getThemeMode();
          const next = NEXT[mode];
          const text = `Theme: ${LABEL[mode]} (click for ${LABEL[next]})`;
          buttons.forEach((b) => {
            b.setAttribute('aria-label', text);
            b.setAttribute('title', text);
          });
        };
        buttons.forEach((button) => {
          const oldHandler = button.themeToggleHandler;
          if (oldHandler) button.removeEventListener('click', oldHandler);
          const handler = function () {
            const next = NEXT[getThemeMode()];
            if (next === 'system') delete localStorage.theme;
            else localStorage.theme = next;
            applyTheme();
            updateLabels();
          };
          button.themeToggleHandler = handler;
          button.addEventListener('click', handler);
        });
        updateLabels();
      }

      // Search — lazy-loads Pagefind UI on first open. The Pagefind index
      // and UI assets are emitted to /pagefind/ during `pnpm build` (the
      // `pagefind --site dist` post-step). In dev (no build run), the
      // /pagefind/ paths 404 silently — search is a prod feature.
      function initSearch() {
        const dialog = document.getElementById('search-dialog');
        const triggers = document.querySelectorAll('[data-search-open]');
        if (!dialog || !triggers.length) return;

        let pagefindLoaded = false;

        async function loadPagefindUI() {
          if (pagefindLoaded) return;
          pagefindLoaded = true;
          const cssLink = document.createElement('link');
          cssLink.rel = 'stylesheet';
          cssLink.href = '/pagefind/pagefind-ui.css';
          document.head.appendChild(cssLink);
          try {
            // String-concat the URL so Vite/Rollup don't try to resolve it
            // at build time — the file is emitted by `pagefind --site dist`
            // AFTER the Astro build, so it doesn't exist when Vite scans.
            const pagefindUrl = '/pagefind' + '/pagefind-ui.js';
            const mod = await import(/* @vite-ignore */ pagefindUrl);
            const PagefindUI = mod.PagefindUI ?? window.PagefindUI;
            new PagefindUI({
              element: '#pagefind-search-target',
              showSubResults: true,
              resetStyles: false,
              showImages: false,
              autofocus: true,
              translations: {
                placeholder: 'Search posts, builds, pages…',
                clear_search: 'Clear',
                load_more: 'Load more results',
                search_label: 'Search Tiny Delights',
                filters_label: 'Filters',
                zero_results: 'No results for [SEARCH_TERM] — try a different word or check spelling.',
                many_results: '[COUNT] results for [SEARCH_TERM]',
                one_result: '[COUNT] result for [SEARCH_TERM]',
                alt_search: 'No results for [SEARCH_TERM]. Showing results for [DIFFERENT_TERM] instead.',
                searching: 'Searching for [SEARCH_TERM]…',
              },
            });
          } catch (err) {
            console.warn('[search] Pagefind UI failed to load — has the site been built? Run `pnpm build` to generate the index.', err);
          }
        }

        async function openSearch() {
          await loadPagefindUI();
          dialog.showModal();
          // Focus the input the UI mounted
          requestAnimationFrame(() => {
            const input = dialog.querySelector('input[type="text"], input[type="search"]');
            if (input) input.focus();
          });
        }

        triggers.forEach((t) => t.addEventListener('click', openSearch));

        // ⌘K / Ctrl+K opens search from anywhere
        document.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
            e.preventDefault();
            openSearch();
          }
          if (e.key === 'Escape' && dialog.open) dialog.close();
        });

        // Click outside closes the dialog
        dialog.addEventListener('click', (e) => {
          if (e.target === dialog) dialog.close();
        });
      }

      function initAll() {
        initMobileMenu();
        initDropdown();
        initThemeToggle();
        initSearch();
      }

      initAll();
      document.addEventListener('astro:after-swap', initAll);
    </script>
  </body>
</html>
